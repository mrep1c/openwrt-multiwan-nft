{
	"luci-app-multiwan-nft": {
		"description": "Grant UCI access for luci-app-multiwan-nft",
		"read": {
			"file": {
				"/etc/multiwan-nft.user": [ "read" ],
				"/usr/bin/httping": [ "list" ],
				"/usr/bin/nping": [ "list" ],
				"/usr/bin/arping": [ "list" ],
				"/usr/sbin/multiwan-nft status": [ "exec" ],
				"/usr/sbin/multiwan-nft ifup *": [ "exec" ],
				"/usr/sbin/multiwan-nft ifdown *": [ "exec" ],
				"/usr/sbin/multiwan-nft internal ipv4": [ "exec" ],
				"/usr/sbin/multiwan-nft internal ipv6": [ "exec" ],
				"/usr/libexec/luci-multiwan-nft diag * *": [ "exec" ],
				"/usr/libexec/luci-multiwan-nft ipset *": [ "exec" ]
			},
			"ubus": {
				"multiwan_nft": [ "status" ]
			},
			"uci": [ "multiwan-nft", "network" ]
		},
		"write": {
			"file": {
				"/etc/multiwan-nft.user": ["write"],
				"/usr/sbin/multiwan-nft ifup *": [ "exec" ],
				"/usr/sbin/multiwan-nft ifdown *": [ "exec" ]
			},
			"uci": [ "multiwan-nft" ]
		}
	}
}
