#!/bin/sh

MULTIWAN_NFT_LIB_ROOT="${MULTIWAN_NFT_LIB_ROOT:-/lib}"
. "$MULTIWAN_NFT_LIB_ROOT/functions.sh"
. "$MULTIWAN_NFT_LIB_ROOT/functions/network.sh"
. "$MULTIWAN_NFT_LIB_ROOT/multiwan-nft/multiwan_nft.sh"
. "$MULTIWAN_NFT_LIB_ROOT/multiwan-nft/process-lock.sh"

RTMON_PID=""
RTMON_START=""
RTMON_SELF_START=""
RTMON_WORK_DIR=""
RTMON_OWNER_TOKEN=""
RTMON_FIFO=""
RTMON_ERROR_FILE=""
RTMON_INIT_LOCK=""
RTMON_CLEANED=0

multiwan_nft_rtmon_child_stop()
{
	local count=0

	if mw_process_identity_alive "$RTMON_PID" "$RTMON_START"; then
		kill "$RTMON_PID" 2>/dev/null
		while mw_process_identity_alive "$RTMON_PID" "$RTMON_START" && [ "$count" -lt 2 ]; do
			sleep 1
			count=$((count + 1))
		done
		if mw_process_identity_alive "$RTMON_PID" "$RTMON_START"; then
			LOG warn "Force killing route monitor child $RTMON_PID"
			kill -KILL "$RTMON_PID" 2>/dev/null
		fi
	fi
	[ -n "$RTMON_PID" ] && wait "$RTMON_PID" 2>/dev/null
	RTMON_PID=""
	RTMON_START=""
}

multiwan_nft_rtmon_cleanup()
{
	[ "$RTMON_CLEANED" -eq 0 ] || return 0
	RTMON_CLEANED=1
	trap - EXIT HUP INT TERM
	multiwan_nft_rtmon_child_stop
	exec 3>&- 2>/dev/null
	exec 3<&- 2>/dev/null
	rm -f "$RTMON_INIT_LOCK"
	if [ -n "$RTMON_WORK_DIR" ] &&
		mw_lock_read_owner "$RTMON_WORK_DIR" &&
		[ "$MW_LOCK_OWNER_PID" = "$$" ] &&
		[ "$MW_LOCK_OWNER_START" = "$RTMON_SELF_START" ] &&
		[ "$MW_LOCK_OWNER_TOKEN" = "$RTMON_OWNER_TOKEN" ]; then
		rm -f "$RTMON_FIFO" "$RTMON_ERROR_FILE" \
			"$RTMON_WORK_DIR/owner" "$RTMON_WORK_DIR"/.owner.* 2>/dev/null
		rmdir "$RTMON_WORK_DIR" 2>/dev/null
	fi
}

multiwan_nft_rtmon_signal()
{
	exit 0
}

multiwan_nft_rtmon_remove_orphans()
{
	local family_flag="$1" pid_dir pid ppid start cmdline count

	for pid_dir in /proc/[0-9]*; do
		[ -r "$pid_dir/cmdline" ] || continue
		pid="${pid_dir##*/}"
		ppid="$(sed -n 's/^PPid:[[:space:]]*//p' "$pid_dir/status" 2>/dev/null)"
		[ "$ppid" = "1" ] || continue
		start="$(mw_process_start_time "$pid" 2>/dev/null)"
		cmdline="$(tr '\0' ' ' 2>/dev/null < "$pid_dir/cmdline")"
		case "$cmdline" in
			"ip -$family_flag monitor route"|"ip -$family_flag monitor route "|\
			"/sbin/ip -$family_flag monitor route"|"/sbin/ip -$family_flag monitor route "|\
			"/usr/sbin/ip -$family_flag monitor route"|"/usr/sbin/ip -$family_flag monitor route ")
				mw_process_identity_alive "$pid" "$start" || continue
				LOG warn "Stopping orphaned IPv$family_flag route monitor process $pid"
				kill "$pid" 2>/dev/null
				count=0
				while mw_process_identity_alive "$pid" "$start" && [ "$count" -lt 2 ]; do
					sleep 1
					count=$((count + 1))
				done
				mw_process_identity_alive "$pid" "$start" && kill -KILL "$pid" 2>/dev/null
				;;
		esac
	done
}

multiwan_nft_rtmon_remove_stale_workdirs()
{
	local family="$1" work_dir

	for work_dir in /tmp/multiwan-nft-rtmon-"$family".*; do
		[ -d "$work_dir" ] && [ ! -L "$work_dir" ] || continue
		mw_lock_read_owner "$work_dir" || continue
		mw_process_identity_alive "$MW_LOCK_OWNER_PID" "$MW_LOCK_OWNER_START" && continue

		LOG warn "Removing stale $family route monitor workspace $work_dir"
		rm -f "$work_dir/events" "$work_dir/error" \
			"$work_dir/owner" "$work_dir"/.owner.* 2>/dev/null
		rmdir "$work_dir" 2>/dev/null
	done
}

multiwan_nft_rtmon_create_workdir()
{
	local family="$1"

	RTMON_SELF_START="$(mw_process_start_time "$$")" || return 1
	RTMON_WORK_DIR="$(mktemp -d "/tmp/multiwan-nft-rtmon-${family}.XXXXXX")" || return 1
	RTMON_OWNER_TOKEN="rtmon:$$:$RTMON_SELF_START:${RTMON_WORK_DIR##*.}"
	if ! mw_lock_write_owner "$RTMON_WORK_DIR" "$$" \
		"$RTMON_SELF_START" "$RTMON_OWNER_TOKEN"; then
		rmdir "$RTMON_WORK_DIR" 2>/dev/null
		RTMON_WORK_DIR=""
		return 1
	fi
	RTMON_FIFO="$RTMON_WORK_DIR/events"
	RTMON_ERROR_FILE="$RTMON_WORK_DIR/error"
}

multiwan_nft_add_all_routes()
{
	local tid IP route_line family active_tbls tid initial_state error
	local ipv=$1

	add_active_tbls()
	{
		let tid++
		config_get family "$1" family ipv4
		config_get initial_state "$1" initial_state "online"
		[ "$family" != "$ipv" ] && return
		if $NFT list chain $NFT_FAMILY $NFT_TABLE "multiwan_nft_iface_in_$1" &> /dev/null; then
			active_tbls="$active_tbls${tid} "
		fi
	}

	add_route()
	{
		let tid++
		[ -n "${active_tbls##* $tid *}" ] && return
		multiwan_nft_route_replace_idempotent "$IP" "$tid" "$route_line"
	}

	multiwan_nft_update_dev_to_table
	[ "$ipv" = "ipv6" ] && [ "$NO_IPV6" -ne 0 ] && return
	if [ "$ipv" = "ipv4" ]; then
		IP="$IP4"
	elif [ "$ipv" = "ipv6" ]; then
		IP="$IP6"
	fi
	tid=0
	active_tbls=" "
	config_foreach add_active_tbls interface
	[ "$active_tbls" = " " ] && return
	multiwan_nft_get_routes | while read -r route_line; do
		multiwan_nft_route_line_dev "tid" "$route_line" "$ipv"
		if [ -n "$tid" ] && [ -z "${active_tbls##* $tid *}" ]; then
			multiwan_nft_route_replace_idempotent "$IP" "$tid" "$route_line"
		elif [ -n "${route_line##default*}" ] && [ -n "${route_line##fe80::/64*}" ]; then
			config_foreach add_route interface
		fi
	done
}

multiwan_nft_rtmon_route_handle()
{
	local action route_line family tbl device line tid

	route_line=${1##"Deleted "}
	route_family=$2

	if [ "$route_line" = "$1" ]; then
		action="replace"
		multiwan_nft_nft_add_set_element "multiwan_nft_connected_${route_family}" "${route_line%% *}"
	else
		action="del"
		multiwan_nft_set_connected_${route_family}
	fi

	if [ -z "${route_line##*linkdown*}" ]; then
		LOG debug "attempting to add link on down interface - $route_line"
	fi

	if [ "$route_family" = "ipv4" ]; then
		IP="$IP4"
	elif [ "$route_family" = "ipv6" ] && [ "$NO_IPV6" -eq 0 ]; then
		IP="$IP6"
	else
		LOG warn "route update called with invalid family - $route_family"
		return
	fi
	route_line=$(echo "$route_line" | sed -ne "$MULTIWAN_NFT_ROUTE_LINE_EXP")

	handle_route() {
		local error
		local iface=$1
		tbl=$($IP route list table $tid 2>/dev/null)$'\n'

		if [ -n "$iface" ] && [ "$(multiwan_nft_get_track_status $iface)" != "active" ]; then
			LOG debug "interface $iface is disabled - skipping '$route_line'";
			return
		fi

		# check that action needs to be performed. May not need to take action if we
		# got a delete event, but table was already flushed
		if [ $action = "del" ] && [ -n "${tbl##*$route_line$'\n'*}" ]; then
			LOG debug "skipping already deleted route table $tid - skipping '$route_line'"
			return
		fi

		network_get_device device "$iface"
		LOG debug "adjusting route $device: '$IP route $action table $tid $route_line'"
		if [ "$action" = "replace" ]; then
			multiwan_nft_route_replace_idempotent "$IP" "$tid" "$route_line"
		else
			error=$($IP route "$action" table $tid $route_line 2>&1)||
				LOG warn "failed: '$IP route $action table $tid $route_line' - error: $error"
		fi
	}
	handle_route_cb(){
		local iface=$1
		let tid++
		config_get family "$iface" family ipv4
		[ "$family" != "$route_family" ] && return
		handle_route "$iface"
	}

	multiwan_nft_update_dev_to_table
	multiwan_nft_route_line_dev "tid" "$route_line" "$route_family"

	if [ -n "$tid" ]; then
		handle_route
	elif [ -n "${route_line##default*}" ] && [ -n "${route_line##fe80::/64*}" ]; then
		config_foreach handle_route_cb interface
	fi
}

main()
{
	local IP family family_flag line child_status error_line

	multiwan_nft_init

	family=$1
	[ -z "$family" ] && family=ipv4
	if [ "$family" = "ipv6" ]; then
		if [ "$NO_IPV6" -ne 0 ]; then
			LOG warn "multiwan-nft-rtmon started for ipv6, but ipv6 not enabled on system"
			exit 1
		fi
		IP="$IP6"
		family_flag=6
	else
		IP="$IP4"
		family_flag=4
	fi

	RTMON_INIT_LOCK="/tmp/multiwan-nft-rtmon_init_${family}"
	trap multiwan_nft_rtmon_cleanup EXIT
	trap multiwan_nft_rtmon_signal HUP INT TERM

	multiwan_nft_rtmon_remove_orphans "$family_flag"
	multiwan_nft_rtmon_remove_stale_workdirs "$family"

	# Use a lock file to synchronize route population
	touch "$RTMON_INIT_LOCK"

	# Populate initial routes
	# Note: multiwan_nft_set_connected_* called from init script to avoid race conditions
	multiwan_nft_add_all_routes "$family"

	# Remove lock file to signal we're ready
	rm -f "$RTMON_INIT_LOCK"

	umask 077
	multiwan_nft_rtmon_create_workdir "$family" || {
		LOG error "Unable to create private IPv$family_flag route monitor workspace"
		return 1
	}
	mkfifo "$RTMON_FIFO" || {
		LOG error "Unable to create route monitor FIFO $RTMON_FIFO"
		return 1
	}

	# Keeping one read/write descriptor open prevents FIFO EOF spin. Integer
	# timed reads let the parent notice a dead monitor without relying on
	# fractional timeout behavior.
	exec 3<> "$RTMON_FIFO" || {
		LOG error "Unable to open route monitor FIFO $RTMON_FIFO"
		return 1
	}
	$IP monitor route > "$RTMON_FIFO" 2> "$RTMON_ERROR_FILE" &
	RTMON_PID=$!
	RTMON_START="$(mw_process_start_time "$RTMON_PID")"
	if [ -z "$RTMON_START" ]; then
		sleep 1
		RTMON_START="$(mw_process_start_time "$RTMON_PID")"
	fi
	[ -n "$RTMON_START" ] || {
		LOG error "Unable to identify route monitor child $RTMON_PID"
		return 1
	}

	while :; do
		line=""
		if ! IFS= read -r -t 5 line <&3; then
			if mw_process_identity_alive "$RTMON_PID" "$RTMON_START"; then
				continue
			fi
			wait "$RTMON_PID" 2>/dev/null
			child_status=$?
			LOG error "IPv$family_flag route monitor exited unexpectedly with status $child_status"
			if [ -s "$RTMON_ERROR_FILE" ]; then
				while IFS= read -r error_line; do
					[ -n "$error_line" ] && LOG error "ip monitor: $error_line"
				done < "$RTMON_ERROR_FILE"
			fi
			return 1
		fi
		[ -n "$line" ] || continue
		[ -z "${line##*table*}" ] && continue
		LOG debug "handling route update $family '$line'"
		multiwan_nft_rtmon_route_handle "$line" "$family"
	done
}
[ "${MULTIWAN_NFT_RTMON_LIBRARY_ONLY:-0}" = "1" ] || main "$@"
